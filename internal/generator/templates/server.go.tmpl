package {{.PackageName}}

import (
	"context"
	"encoding/json"
	"errors"
	"fmt"

	kafkaWrapper "{{.KafkaImport}}"
)
{{range .Services}}
type {{.Name}}Handler interface {
{{- range .Methods}}
	{{.Name}}(ctx context.Context, req *{{.ReqType}}) error
{{- end}}
}
{{end}}
type ServerConfig struct {
	Kafka *kafkaWrapper.ConfigConsumer
}

type serverRouter struct {
	globalCtx       context.Context
	globalCtxCancel context.CancelFunc
{{- range .Services}}
	{{lowerFirst .Name}}Handler {{.Name}}Handler
{{- end}}
	consumer kafkaWrapper.Consumer
}

func NewServer(cfg ServerConfig,
{{- range .Services}}
	{{lowerFirst .Name}} {{.Name}}Handler,
{{- end}}
) (*serverRouter, error) {
	consumer, err := kafkaWrapper.NewConsumer(cfg.Kafka)
	if err != nil {
		return nil, fmt.Errorf("create consumer: %w", err)
	}

	ctx, cancel := context.WithCancel(context.Background())

	return &serverRouter{
{{- range .Services}}
		{{lowerFirst .Name}}Handler: {{lowerFirst .Name}},
{{- end}}
		consumer:        consumer,
		globalCtx:       ctx,
		globalCtxCancel: cancel,
	}, nil
}

func (s *serverRouter) Run() error {
	if err := s.consumer.Consume(s.globalCtx, s.route); err != nil {
		if errors.Is(err, context.Canceled) {
			return nil
		}
		return err
	}
	return nil
}

func (s *serverRouter) Close() error {
	s.globalCtxCancel()
	return s.consumer.Close()
}

func (s *serverRouter) route(ctx context.Context, msg *kafkaWrapper.KafkaMessage) error {
	var ev event
	if err := json.Unmarshal(msg.Value, &ev); err != nil {
		return fmt.Errorf("unmarshal event: %w", err)
	}

	switch ev.Type {
{{- range .Services}}
{{- $svc := .}}
{{- range .Methods}}
	case event{{.Name}}:
		var req {{.ReqType}}
		if err := json.Unmarshal(ev.Data, &req); err != nil {
			return fmt.Errorf("unmarshal {{.ReqType}}: %w", err)
		}
		return s.{{lowerFirst $svc.Name}}Handler.{{.Name}}(ctx, &req)
{{- end}}
{{- end}}
	default:
		return nil
	}
}
